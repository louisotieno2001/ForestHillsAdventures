<script>
document.addEventListener('DOMContentLoaded', function() {
    const serviceRadios = document.querySelectorAll('input[name="service_type"]');
    const serviceDetails = document.getElementById('service-details');
    const travelHeading = document.getElementById('travel-details-heading');
    const additionalHeading = document.getElementById('additional-info-heading');
    const serviceForms = {
        'conference': document.getElementById('conference-details'),
        'guided-tour': document.getElementById('guided-tour-details'),
        'unguided-tour': document.getElementById('unguided-tour-details'),
        'safari': document.getElementById('safari-details'),
        'cultural-tour': document.getElementById('cultural-tour-details'),
        'adventure': document.getElementById('adventure-details'),
        'honeymoon': document.getElementById('honeymoon-details'),
        'family': document.getElementById('family-details'),
        'group': document.getElementById('group-details'),
        'cruise': document.getElementById('cruise-details'),
        'short-stay': document.getElementById('short-stay-details'),
        'long-stay': document.getElementById('long-stay-details'),
        'car-hire': document.getElementById('car-hire-details'),
        'hotels': document.getElementById('hotels-details'),
        'air-tickets': document.getElementById('air-tickets-details'),
        'visa': document.getElementById('visa-details'),
        'travel-insurance': document.getElementById('travel-insurance-details'),
        'full-package': document.getElementById('full-package-details')
    };

    function updateForm() {
        let selectedService = 'conference';
        serviceRadios.forEach(radio => {
            if (radio.checked) {
                selectedService = radio.value;
            }
        });

        serviceDetails.style.display = 'block';

        Object.keys(serviceForms).forEach(key => {
            if (serviceForms[key]) {
                serviceForms[key].style.display = 'none';
            }
        });

        if (serviceForms[selectedService]) {
            serviceForms[selectedService].style.display = 'block';
        }
    }

    serviceRadios.forEach(radio => {
        radio.addEventListener('change', updateForm);
    });

    updateForm();
});
</script>

