                            <label class="checkbox-item"><input type="checkbox" name="cultural_communities" value="maasai"><span>Maasai</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="cultural_communities" value="kikuyu"><span>Kikuyu</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="cultural_communities" value="swahili"><span>Swahili Coast</span></label>
