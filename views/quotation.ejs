<%- include('partials/header') %>

<main class="modern-page">
    <section class="inner-hero">
        <h1>Get a Quotation</h1>
        <p>Ready to start your adventure? Fill in the details below and our travel experts will craft the perfect package for you.</p>
    </section>

    <div class="modern-content">
        <form action="/submit-quotation" method="POST">
            <div class="form-group">
                <h3>1. Contact Information</h3>
                <div class="input-row">
                    <div class="field">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="field">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>
                </div>
                <div class="input-row">
                    <div class="field">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="+254 7XX XXX XXX" required>
                    </div>
                    <div class="field">
                        <label for="destination">Destination</label>
                        <input type="text" id="destination" name="destination" placeholder="e.g., Maasai Mara, Mombasa" required>
                    </div>
                </div>
                <div class="field">
                    <label>Current Location</label>
                    <div class="input-row">
                        <input type="text" id="country" name="country" placeholder="Country" required>
                        <input type="text" id="town" name="town" placeholder="Town/City" required>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <h3>2. Service Type</h3>
                <div class="selection-grid">
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="tours" checked>
                        <div class="card-content">Guided Tours</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="car-hire">
                        <div class="card-content">Car Hire</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="hotels">
                        <div class="card-content">Hotel Booking</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="flights">
                        <div class="card-content">Air Ticketing</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="packages">
                        <div class="card-content">Full Package</div>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <h3>3. Travel Details</h3>
                <div class="input-row">
                    <div class="field">
                        <label for="travel_date">Preferred Travel Date</label>
                        <input type="date" id="travel_date" name="travel_date" required>
                    </div>
                    <div class="field">
                        <label for="num_travelers">Number of Travelers</label>
                        <input type="number" id="num_travelers" name="num_travelers" placeholder="e.g., 2" min="1" required>
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-top: 4rem;">
                <h3>4. Additional Information</h3>
                <textarea id="message" name="message" placeholder="Tell us about your preferences, special requirements, or any questions you have..."></textarea>
            </div>

            <div style="text-align: center; margin-top: 5rem;">
                <button type="submit" class="btn" style="padding: 1rem 4rem; font-size: 1.1rem; border-radius: 50px;">Request Quotation</button>
            </div>
        </form>
    </div>
</main>

<%- include('partials/footer') %>
