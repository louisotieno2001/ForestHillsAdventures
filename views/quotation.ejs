                            <label for="cultural_depth">Experience Depth</label>
                            <select id="cultural_depth" name="cultural_depth">
                                <option value="">Select depth</option>
                                <option value="overview">Overview Tour</option>
                                <option value="immersive">Immersive Experience</option>
                                <option value="homestay">Homestay Option</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="cultural_participate">Would you like to participate in activities?</label>
                        <select id="cultural_participate" name="cultural_participate">
                            <option value="">Select option</option>
                            <option value="observe">Observe Only</option>
                            <option value="some">Some Hands-on Activities</option>
