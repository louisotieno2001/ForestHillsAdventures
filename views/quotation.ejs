<%- include('partials/header') %>

<main class="modern-page">
    <section class="inner-hero">
        <h1>Get a Quotation</h1>
        <p>Ready to start your adventure? Fill in the details below and our travel experts will craft the perfect package for you.</p>
    </section>

    <div class="modern-content">
        <form action="/submit-quotation" method="POST">
            <div class="form-group">
                <h3>1. Contact Information</h3>
                <div class="input-row">
                    <div class="field">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="field">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>
                </div>
                <div class="input-row">
                    <div class="field">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" placeholder="+254 7XX XXX XXX" required>
                    </div>
                    <div class="field">
                        <label for="destination">Destination</label>
                        <input type="text" id="destination" name="destination" placeholder="e.g., Maasai Mara, Mombasa" required>
                    </div>
                </div>
                <div class="field">
                    <label>Current Location</label>
                    <div class="input-row">
                        <input type="text" id="country" name="country" placeholder="Country" required>
                        <input type="text" id="town" name="town" placeholder="Town/City" required>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <h3>2. Service Type</h3>
                <div class="selection-grid">
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="conference" checked>
                        <div class="card-content">Conference & Events</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="guided-tour">
                        <div class="card-content">Guided Tour</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="unguided-tour">
                        <div class="card-content">Self-Drive / Unguided Tour</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="safari">
                        <div class="card-content">Safari</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="cultural-tour">
                        <div class="card-content">Cultural & Heritage Tour</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="adventure">
                        <div class="card-content">Adventure Tour</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="honeymoon">
                        <div class="card-content">Honeymoon / Romantic</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="family">
                        <div class="card-content">Family Vacation</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="group">
                        <div class="card-content">Group Tour</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="cruise">
                        <div class="card-content">Cruise</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="short-stay">
                        <div class="card-content">Short Stay Apartment</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="long-stay">
                        <div class="card-content">Long Stay Apartment</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="car-hire">
                        <div class="card-content">Car Hire</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="hotels">
                        <div class="card-content">Hotel Booking</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="air-tickets">
                        <div class="card-content">Air Ticketing</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="visa">
                        <div class="card-content">Visa Assistance</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="travel-insurance">
                        <div class="card-content">Travel Insurance</div>
                    </label>
                    <label class="selection-card">
                        <input type="radio" name="service_type" value="full-package">
                        <div class="card-content">Full Package</div>
                    </label>
                </div>
            </div>

            <div id="service-details" class="form-group" style="display: none;">
                <h3>3. Service Details</h3>

                <div id="conference-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Conference & Events Planning Details</h4>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="conference_type">Event Type</label>
                            <select id="conference_type" name="conference_type">
                                <option value="">Select event type</option>
                                <option value="corporate">Corporate Conference</option>
                                <option value="seminar">Seminar / Workshop</option>
                                <option value="training">Training Session</option>
                                <option value="product-launch">Product Launch</option>
                                <option value="annual-meeting">Annual General Meeting</option>
                                <option value="board-meeting">Board Meeting</option>
                                <option value="team-building">Team Building Event</option>
                                <option value="award-ceremony">Award Ceremony</option>
                                <option value="exhibition">Exhibition / Trade Show</option>
                                <option value="wedding">Wedding / Private Event</option>
                                <option value="birthday">Birthday Celebration</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="conference_attendees">Expected Attendees</label>
                            <select id="conference_attendees" name="conference_attendees">
                                <option value="">Select number</option>
                                <option value="small">Small (10-30)</option>
                                <option value="medium">Medium (31-100)</option>
                                <option value="large">Large (101-300)</option>
                                <option value="xlarge">Extra Large (300+)</option>
                            </select>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="conference_date">Event Date</label>
                            <input type="date" id="conference_date" name="conference_date">
                        </div>
                        <div class="field">
                            <label for="conference_duration">Event Duration</label>
                            <select id="conference_duration" name="conference_duration">
                                <option value="">Select duration</option>
                                <option value="half-day">Half Day</option>
                                <option value="full-day">Full Day</option>
                                <option value="multi-day">Multi-Day</option>
                                <option value="week">One Week</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="conference_venue">Venue Preference</label>
                        <select id="conference_venue" name="conference_venue">
                            <option value="">Select venue type</option>
                            <option value="hotel-ballroom">Hotel Ballroom</option>
                            <option value="conference-center">Conference Center</option>
                            <option value="boardroom">Boardroom / Meeting Room</option>
                            <option value="outdoor">Outdoor / Garden Venue</option>
                            <option value="virtual">Virtual / Hybrid</option>
                            <option value="open">Open to Suggestions</option>
                        </select>
                    </div>
                    <div class="field">
                        <label>Services Required</label>
                        <div class="checkbox-grid">
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="venue"><span>Venue Booking</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="catering"><span>Catering</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="av-equipment"><span>AV Equipment</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="projector"><span>Projector / Screens</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="microphones"><span>Microphones</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="livestream"><span>Live Streaming</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="photography"><span>Photography / Videography</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="branding"><span>Branding / Signage</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="transport"><span>Transport / Shuttle</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="accommodation"><span>Accommodation</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="entertainment"><span>Entertainment</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="conference_services" value="security"><span>Security</span></label>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="conference_budget">Budget Range</label>
                            <select id="conference_budget" name="conference_budget">
                                <option value="">Select budget</option>
                                <option value="budget">Budget ($1,000-5,000)</option>
                                <option value="mid">Mid-Range ($5,000-15,000)</option>
                                <option value="premium">Premium ($15,000-50,000)</option>
                                <option value="luxury">Luxury ($50,000+)</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="conference_catering">Catering Style</label>
                            <select id="conference_catering" name="conference_catering">
                                <option value="">Select style</option>
                                <option value="buffet">Buffet</option>
                                <option value="plated">Plated Dinner</option>
                                <option value="cocktail">Cocktail Reception</option>
                                <option value="break">Coffee Breaks Only</option>
                                <option value="working-lunch">Working Lunch</option>
                                <option value="custom">Custom Menu</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="conference_special">Special Requirements</label>
                        <textarea id="conference_special" name="conference_special" rows="3" placeholder="Any specific themes, dietary requirements, accessibility needs, or special arrangements..."></textarea>
                    </div>
                </div>

                <div id="guided-tour-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Guided Tour Details</h4>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="guided_tour_type">Tour Type</label>
                            <select id="guided_tour_type" name="guided_tour_type">
                                <option value="">Select tour type</option>
                                <option value="full-day">Full Day Tour</option>
                                <option value="half-day">Half Day Tour</option>
                                <option value="multi-day">Multi-Day Tour</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="guided_guide_language">Preferred Guide Language</label>
                            <select id="guided_guide_language" name="guided_guide_language">
                                <option value="">Select language</option>
                                <option value="english">English</option>
                                <option value="swahili">Swahili</option>
                                <option value="french">French</option>
                                <option value="german">German</option>
                                <option value="spanish">Spanish</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label>Special Interests</label>
                        <div class="checkbox-grid">
                            <label class="checkbox-item"><input type="checkbox" name="guided_interests" value="wildlife"><span>Wildlife</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="guided_interests" value="photography"><span>Photography</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="guided_interests" value="birding"><span>Birding</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="guided_interests" value="nature"><span>Nature</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="guided_interests" value="history"><span>History</span></label>
                        </div>
                    </div>
                    <div class="field">
                        <label for="guided_meal_preference">Meal Preference</label>
                        <select id="guided_meal_preference" name="guided_meal_preference">
                            <option value="">Select preference</option>
                            <option value="included">Meals Included</option>
                            <option value="breakfast-only">Breakfast Only</option>
                            <option value="own-arrangement">Own Arrangements</option>
                        </select>
                    </div>
                </div>

                <div id="unguided-tour-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Self-Drive / Unguided Tour Details</h4>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="unguided_trip_duration">Trip Duration</label>
                            <select id="unguided_trip_duration" name="unguided_trip_duration">
                                <option value="">Select duration</option>
                                <option value="hours">Few Hours</option>
                                <option value="one-day">One Day</option>
                                <option value="weekend">Weekend (2-3 Days)</option>
                                <option value="one-week">One Week</option>
                                <option value="multi-week">Multi-Week</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="unguided_vehicle_option">Vehicle Option</label>
                            <select id="unguided_vehicle_option" name="unguided_vehicle_option">
                                <option value="">Select option</option>
                                <option value="hire-car">Hiring a Car</option>
                                <option value="own-car">Coming with Own Vehicle</option>
                                <option value="public-transport">Using Public Transport</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="unguided_driving_license">Do You Know How to Drive?</label>
                        <select id="unguided_driving_license" name="unguided_driving_license">
                            <option value="">Select option</option>
                            <option value="yes">Yes, I have a valid license</option>
                            <option value="yes-international">Yes, with International Permit</option>
                            <option value="no">No, I need a driver</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="unguided_vehicle_type">Vehicle Type Needed (if hiring)</label>
                        <select id="unguided_vehicle_type" name="unguided_vehicle_type">
                            <option value="">Select vehicle type</option>
                            <option value="sedan">Sedan / Saloon</option>
                            <option value="suv">SUV / 4x4</option>
                            <option value="minivan">Minivan</option>
                            <option value="luxury">Luxury Vehicle</option>
                            <option value="camper">Camper Van</option>
                        </select>
                    </div>
                    <div class="field">
                        <label>Food & Accommodation Preferences</label>
                        <div class="input-row">
                            <div class="field">
                                <label for="unguided_food">Bringing Own Food?</label>
                                <select id="unguided_food" name="unguided_food">
                                    <option value="">Select option</option>
                                    <option value="yes">Yes, I will bring my own</option>
                                    <option value="no">No, need restaurant recommendations</option>
                                    <option value="catering">Need Catering Service</option>
                                </select>
                            </div>
                            <div class="field">
                                <label for="unguided_accommodation">Accommodation Style</label>
                                <select id="unguided_accommodation" name="unguided_accommodation">
                                    <option value="">Select preference</option>
                                    <option value="camping">Camping</option>
                                    <option value="lodges">Lodges</option>
                                    <option value="hotels">Hotels</option>
                                    <option value="mixed">Mix of Both</option>
                                    <option value="not-needed">Not Needed (Day Trip)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="field">
                        <label for="unguided_experience_level">Driving Experience in Africa?</label>
                        <select id="unguided_experience_level" name="unguided_experience_level">
                            <option value="">Select option</option>
                            <option value="first-time">First Time - Need Route Advice</option>
                            <option value="some-experience">Some Experience</option>
                            <option value="experienced">Experienced</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="unguided_route_preference">Route Preference</label>
                        <select id="unguided_route_preference" name="unguided_route_preference">
                            <option value="">Select preference</option>
                            <option value="scenic">Scenic / Leisure</option>
                            <option value="direct">Direct / Shortest</option>
                            <option value="adventurous">Off-the-Beaten-Path</option>
                            <option value="flexible">Flexible</option>
                        </select>
                    </div>
                </div>

                <div id="safari-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Safari Details</h4>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="safari_type">Safari Type</label>
                            <select id="safari_type" name="safari_type">
                                <option value="">Select safari type</option>
                                <option value="game-drive">Game Drive</option>
                                <option value="bush-walk">Bush Walk / Walking Safari</option>
                                <option value="balloon">Balloon Safari</option>
                                <option value="horseback">Horseback Safari</option>
                                <option value="camel">Camel Safari</option>
                                <option value="fly-camping">Fly Camping</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="safari_duration">Safari Duration</label>
                            <select id="safari_duration" name="safari_duration">
                                <option value="">Select duration</option>
                                <option value="day">Day Safari</option>
                                <option value="overnight">Overnight Safari</option>
                                <option value="multi-day">Multi-Day Safari</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label>Wildlife Priorities</label>
                        <div class="checkbox-grid">
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="big-five"><span>Big Five</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="big-cats"><span>Big Cats</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="elephants"><span>Elephants</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="migrating-wildebeest"><span>Wildebeest Migration</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="birds"><span>Bird Watching</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="safari_interests" value="marine"><span>Marine Life</span></label>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="safari_accommodation">Accommodation Level</label>
                            <select id="safari_accommodation" name="safari_accommodation">
                                <option value="">Select level</option>
                                <option value="budget">Budget / Campsite</option>
                                <option value="mid-range">Mid-Range Lodge</option>
                                <option value="luxury">Luxury Lodge</option>
                                <option value="premium">Premium Tented Camp</option>
                            </select>
                        </div>
                        <div class="field">
                            <label for="safari_vehicle">Vehicle Preference</label>
                            <select id="safari_vehicle" name="safari_vehicle">
                                <option value="">Select preference</option>
                                <option value="shared">Shared Game Drive</option>
                                <option value="private">Private Vehicle</option>
                                <option value="self-drive">Self-Drive</option>
                            </select>
                        </div>
                    </div>
                    <div class="field">
                        <label for="safari_photography">Photography Interest</label>
                        <select id="safari_photography" name="safari_photography">
                            <option value="">Select option</option>
                            <option value="casual">Casual (Phone Camera)</option>
                            <option value="enthusiast">Enthusiast (DSLR/Mirrorless)</option>
                            <option value="professional">Professional Equipment</option>
                        </select>
                    </div>
                </div>

                <div id="cultural-tour-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Cultural & Heritage Tour Details</h4>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="cultural_focus">Cultural Focus</label>
                            <select id="cultural_focus" name="cultural_focus">
                                <option value="">Select focus</option>
                                <option value="tribal">Tribal Culture</option>
