                <div id="adventure-details" class="service-form">
                    <div class="service-form-header">
                        <h4>Adventure Tour Details</h4>
                    </div>
                    <div class="field">
                        <label>Adventure Activities</label>
                        <div class="checkbox-grid">
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="hiking"><span>Hiking / Trekking</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="mountaineering"><span>Mountaineering</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="rafting"><span>White Water Rafting</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="diving"><span>Diving / Snorkeling</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="bungee"><span>Bungee Jumping</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="sky-diving"><span>Sky Diving</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="kayaking"><span>Kayaking / Canoeing</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="cycling"><span>Mountain Cycling</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="surfing"><span>Surfing</span></label>
                            <label class="checkbox-item"><input type="checkbox" name="adventure_activities" value="paragliding"><span>Paragliding</span></label>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="field">
                            <label for="adventure_difficulty">Fitness Level</label>
                            <select id="adventure_difficulty" name="adventure_difficulty">
                                <option value="">Select level</option>
                                <option value="beginner">Beginner</option>
                                <option value="intermediate">Intermediate</option>
                                <option value="advanced">Advanced</option>
                                <option value="expert">Expert</option>
                            </select>
