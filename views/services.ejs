<%- include('partials/header') %>

<main class="modern-page">
    <section class="inner-hero">
        <h1>Our Services</h1>
        <p>Comprehensive travel solutions tailored to make your journeys seamless, memorable, and truly extraordinary.</p>
    </section>

    <div class="modern-content">
        <div class="services-section">
            <div class="service-row" id="tours">
                <div class="service-image" style="background-image: url('/images/tours.png');"></div>
                <div class="service-text">
                    <h2>Guided Tours</h2>
                    <p>Embark on curated adventures led by passionate local experts. From thrilling safaris in Maasai Mara to the serene beauty of the Kenyan coast, our tours cover the most breathtaking destinations.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Safari Adventures</li>
                        <li><i class="fas fa-check-circle"></i> Cultural Tours</li>
                        <li><i class="fas fa-check-circle"></i> Mountain Expeditions</li>
                        <li><i class="fas fa-check-circle"></i> City Walking Tours</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Book a Tour</a>
                </div>
            </div>

            <div class="service-row" id="car-hire">
                <div class="service-image" style="background-image: url('/images/car-hire.jpg');"></div>
                <div class="service-text">
                    <h2>Car Hire</h2>
                    <p>Explore at your own pace with our diverse fleet of well-maintained vehicles. Whether you need a rugged 4x4 for off-road adventures or a comfortable sedan for city drives, we have the perfect vehicle for you.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> 4x4 Safari Vehicles</li>
                        <li><i class="fas fa-check-circle"></i> Economy Cars</li>
                        <li><i class="fas fa-check-circle"></i> Luxury Vehicles</li>
                        <li><i class="fas fa-check-circle"></i> Self-Drive & Chauffeur Options</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Hire a Car</a>
                </div>
            </div>

            <div class="service-row" id="hotels">
                <div class="service-image" style="background-image: url('/images/hotel-booking.webp');"></div>
                <div class="service-text">
                    <h2>Hotel Bookings</h2>
                    <p>Find the perfect accommodation for every budget and preference. From luxury five-star resorts with stunning ocean views to intimate boutique hotels in the heart of the city, we partner with the best to ensure your comfort.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Luxury Resorts</li>
                        <li><i class="fas fa-check-circle"></i> Boutique Hotels</li>
                        <li><i class="fas fa-check-circle"></i> Budget Accommodations</li>
                        <li><i class="fas fa-check-circle"></i> Eco-Lodges</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Book a Stay</a>
                </div>
            </div>

            <div class="service-row" id="flights">
                <div class="service-image" style="background-image: url('/images/flights.webp');"></div>
                <div class="service-text">
                    <h2>Air Ticketing</h2>
                    <p>Navigate the skies with ease. Our air ticketing service offers competitive fares on domestic and international routes, with expert guidance to help you find the best connections and deals.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Domestic Flights</li>
                        <li><i class="fas fa-check-circle"></i> International Flights</li>
                        <li><i class="fas fa-check-circle"></i> Multi-City Itineraries</li>
                        <li><i class="fas fa-check-circle"></i> Group Bookings</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">Find Flights</a>
                </div>
            </div>

            <div class="service-row" id="packages">
                <div class="service-image" style="background-image: url('/images/packages.png');"></div>
                <div class="service-text">
                    <h2>Travel Packages</h2>
                    <p>Experience worry-free travel with our all-inclusive packages. We handle everything from flights and accommodations to activities and transfers, so you can focus on making memories.</p>
                    <ul class="service-features">
                        <li><i class="fas fa-check-circle"></i> Safari Packages</li>
                        <li><i class="fas fa-check-circle"></i> Beach Holidays</li>
                        <li><i class="fas fa-check-circle"></i> Honeymoon Packages</li>
                        <li><i class="fas fa-check-circle"></i> Corporate Travel</li>
                    </ul>
                    <a href="/get-quotation" class="btn" style="margin-top: 2rem;">View Packages</a>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
